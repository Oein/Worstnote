# Notee backend — copy to `.env` and fill in.
#
# Path layout assumes a TrueNAS dataset such as `tank/apps/notee` with two
# child datasets (postgres, minio). On other hosts use any directory.

# ── Persistent data root (host path) ────────────────────────────────────────
DATA_DIR=/mnt/tank/apps/notee

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=notee
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=notee

# ── MinIO (S3-compatible object store) ──────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-please-too
MINIO_S3_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=notee-assets

# ── Notee API ───────────────────────────────────────────────────────────────
NOTEE_API_IMAGE=ghcr.io/oein/notee-api:latest
API_PORT=8080
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string
